  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && node scripts/prepare-pages.js && vite build && node scripts/postbuild.js",
    "pages-preview": "vite preview --host 127.0.0.1 --port 4173",
    "lint": "eslint .",
