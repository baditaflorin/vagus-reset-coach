#!/usr/bin/env bash
set -euo pipefail

message_file="${1:?commit message file required}"
first_line="$(head -n 1 "$message_file")"

if [[ ! "$first_line" =~ ^(feat|fix|docs|chore|refactor|test|ops|data|build)(\([a-z0-9_-]+\))?!?:\ .+ ]]; then
  echo "Commit message must use Conventional Commits, for example: feat: add rppg signal meter"
  exit 1
fi
